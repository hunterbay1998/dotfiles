{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "strict": true,
    "module": "ES2022",
    "target": "ES2020",
    "lib": ["ES2023"],
    "moduleResolution": "Bundler",
    // "checkJs": true,
    // "allowJs": true,
    "jsx": "react-jsx",
    "jsxImportSource": "ags/gtk4",
    "paths": {
      "ags/gtk4/jsx-runtime": ["./node_modules/ags/lib/gtk4/jsx-runtime.ts"]
    }
  }
}
