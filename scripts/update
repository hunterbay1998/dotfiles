#!/usr/bin/env bash

choice=$(printf "%s\n" \
  "Pacman (system)" \
  "AUR (yay)" \
  "Flatpak" \
  "Everything" \
  "Check updates only" \
  "Exit" \
  | fzf --prompt="Update > ")

case "$choice" in
  "Pacman (system)")
    sudo pacman -Syu
    ;;
  "AUR (yay)")
    yay -Syu
    ;;
  "Flatpak")
    flatpak update
    ;;
  "Everything")
    sudo pacman -Syu
    yay -Syu
    flatpak update
    ;;
  "Check updates only")
    echo
    echo "Pacman:"
    checkupdates || echo "No pacman updates"
    echo
    echo "AUR:"
    yay -Qua || echo "No AUR updates"
    echo
    echo "Flatpak:"
    flatpak remote-ls --updates
    ;;
  *)
    exit 0
    ;;
esac

