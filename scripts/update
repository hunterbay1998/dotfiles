#!/usr/bin/env bash

# Pick AUR helper: prefer paru, fallback to yay, skip if neither
if command -v paru &>/dev/null; then
  aur=paru
elif command -v yay &>/dev/null; then
  aur=yay
else
  aur=""
fi

choice=$(printf "%s\n" \
  "Pacman (system)" \
  "AUR" \
  "Flatpak" \
  "Everything" \
  "Check updates only" \
  "Exit" \
  | fzf --prompt="Update > ")

case "$choice" in
  "Pacman (system)")
    sudo pacman -Syu
    ;;
  "AUR")
    [ -n "$aur" ] && $aur -Syu || echo "No AUR helper installed"
    ;;
  "Flatpak")
    flatpak update
    ;;
  "Everything")
    sudo pacman -Syu
    [ -n "$aur" ] && $aur -Syu
    flatpak update
    ;;
  "Check updates only")
    echo
    echo "Pacman:"
    checkupdates || echo "No pacman updates"
    echo
    echo "AUR:"
    [ -n "$aur" ] && $aur -Qua || echo "No AUR helper installed"
    echo
    echo "Flatpak:"
    flatpak remote-ls --updates
    ;;
  *)
    exit 0
    ;;
esac

