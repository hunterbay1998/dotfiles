/>


Revealer
--------
<revealer
  transitionType={Gtk.RevealerTransitionType.SLIDE_RIGHT}
  transitionDuration={300}
  revealChild={revealed()}
  onNotifyChildRevealed={(self) => {
    if (!self.childRevealed) win.hide()
  }}
/>


Window
------
<window
  visible                               // invisible by default in GTK4!
  namespace="bar"
  gdkmonitor={monitor}                  // prefer over monitor={0}
  exclusivity={Astal.Exclusivity.EXCLUSIVE}
  keymode={Astal.Keymode.ON_DEMAND}
  anchor={Astal.WindowAnchor.TOP | Astal.WindowAnchor.LEFT | Astal.WindowAnchor.RIGHT}
/>


Centerbox slots
---------------
<centerbox>
  <Child $type="start" />
  <Child $type="center" />
  <Child $type="end" />
</centerbox>


Dynamic Rendering
-----------------
<With value={accessor}>
  {(value) => value && <label label={value.member} />}
</With>

<For each={listAccessor}>
  {(item) => <label label={item} />}
</For>
// always wrap With/For in a container — they append on change


Misc / Gotchas
--------------
- windows invisible by default — always pass visible prop
- cssClasses not cssName for CSS styling
- use gdkmonitor not monitor for multi-monitor
- env vars: GLib.getenv("HOME") not exec("echo $HOME")
- logging: print() → stdout, printerr() → stderr
- GObject list props: use getter method eg. notifd.get_notifications()
