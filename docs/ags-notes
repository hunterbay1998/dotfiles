State
-----
const [value, setValue] = createState(0)
// read: value()   write: setValue(newVal) or setValue(v => v + 1)

const binding = createBinding(gobject, "propertyName")

const derived = createComputed(() => value().toString())
const derived = value((v) => v.toString())  // shorthand


